      <diffuse>0.2 0.3 0.8 1.0</diffuse>
    </material>
  </gazebo>
  <!-- ============================================ -->
  <!-- Ackermann steering system plugin             -->
  <!-- ============================================ -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <!-- Rear drive joints -->
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <!-- Front steering joints -->
      <left_steering_joint>front_left_steering</left_steering_joint>
      <right_steering_joint>front_right_steering</right_steering_joint>
      <!-- Geometry -->
      <wheel_base>0.28</wheel_base>
      <wheel_separation>0.2</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <!-- Dynamics -->
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <velocity_command_timeout>0.8</velocity_command_timeout>
      <!-- Topics & TF -->
      <odom_publish_frequency>10</odom_publish_frequency>
